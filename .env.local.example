# MUN MIND — Environment Variables
# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored. Never commit real secrets.

# --- LLM Providers ---
# Primary: Gemini 2.5 Pro for initial check-in assessment (100 req/day free tier)
# Get a key at https://ai.google.dev
GOOGLE_AI_STUDIO_API_KEY=

# Fallback + conversation: Groq Llama 3.3 70B (1,000 req/day free tier)
# Get a key at https://console.groq.com
GROQ_API_KEY=

# --- Supabase ---
# Create a free project at https://supabase.com
# URL is public-safe (prefixed with NEXT_PUBLIC_); anon key is public-safe (RLS enforces permissions)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Used for admin dashboard queries that bypass RLS.
# Never expose to the browser. Never commit.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin Dashboard ---
# Shared secret for the demo-grade admin dashboard (Phase 15.4).
# Replace with proper SSO before production deployment to MUN.
ADMIN_PASSPHRASE=
